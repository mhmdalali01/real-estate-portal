    "# Seed SQL Debug\n",
    "Compute a bcrypt hash for password123 and verify the seed file password hash."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "44361f36",
   "metadata": {},
   "outputs": [],
   "source": [
    "import bcrypt\n",
    "password = b'password123'\n",
    "hash = bcrypt.hashpw(password, bcrypt.gensalt(rounds=10))\n",
    "print(hash.decode())"
   ]
  }
